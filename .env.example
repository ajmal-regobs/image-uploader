# S3 — credentials come from the IAM role attached to the EC2/ECS/EKS host.
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
S3_BUCKET_NAME=image-saver-uploads-prod-us-east-1
S3_REGION=us-east-1

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=image_uploader
DB_USER=postgres
DB_PASSWORD=postgres

# Flask
FLASK_SECRET=change-me
MAX_UPLOAD_MB=10
